<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>宝宝爱AI - 持续更新的AI工作门户</title>
  <meta name="description" content="宝宝爱AI是一个持续更新的中文AI门户网站，展示AI作品、记录AI工作日志、分享提示词和工具经验。">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <nav class="nav-bar glass-nav">
    <a href="index.html" class="nav-logo">宝宝爱AI</a>
    <div class="nav-menu">
      <a href="index.html" class="nav-item active">首页</a>
      <a href="logs.html" class="nav-item">日志</a>
      <a href="works.html" class="nav-item">作品</a>
      <a href="bbs.html" class="nav-item">讨论组</a>
      <a href="share.html" class="nav-item">AI分享</a>
      <a href="business.html" class="nav-item">商务洽谈</a>
    </div>
    <div class="nav-right">
      <button class="nav-btn search-btn">
        <svg viewBox="0 0 24 24">
          <path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
      <button class="nav-btn more-btn">
        <svg viewBox="0 0 24 24">
          <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
        </svg>
      </button>
      <button class="nav-btn mobile-menu-btn">
        <svg viewBox="0 0 24 24">
          <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
        </svg>
      </button>
    </div>
  </nav>

  <div class="hero-slider">
    <div class="slider-container">
      <div class="slide">
        <div class="slide-base-image" style="background-image: url('https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260609_195923_b0ba8ace-1d1d-4f2c-9a28-1ab84b330680.png&w=1280&q=85');"></div>
        <div class="slide-reveal-layer">
          <canvas class="reveal-canvas"></canvas>
          <div class="slide-reveal-image" style="background-image: url('https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260609_201152_bba90a12-bf12-459f-91f0-51f237dbaf3b.png&w=1280&q=85');"></div>
        </div>
        <div class="slide-content">
          <canvas class="particle-canvas" data-text="持续更新的AI工作门户"></canvas>
          <a href="works.html" class="slide-cta">开始探索</a>
        </div>
      </div>
      <div class="slide gradient-dots-slide">
        <div class="slide-black-bg"></div>
        <canvas class="gradient-dots-canvas"></canvas>
        <div class="slide-content">
          <canvas class="particle-canvas" data-text="AI作品"></canvas>
          <canvas class="particle-canvas" data-text="网站、自动化、内容生产"></canvas>
          <a href="works.html" class="slide-cta">浏览作品</a>
        </div>
      </div>
      <div class="slide spatial-dark-slide">
        <div class="slide-black-bg"></div>
        <div class="spatial-hero-container">
          <canvas class="spatial-canvas"></canvas>
          <div class="spatial-glass-bar">
            <div class="spatial-search-input-wrapper">
              <svg class="spatial-search-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
              <input type="text" class="spatial-search-input" placeholder="全站搜索 AI 内容、提示词、工具...">
              <div class="spatial-search-suggestions">
                <span class="search-tag">提示词</span>
                <span class="search-tag">AI工具</span>
                <span class="search-tag">自动化</span>
                <span class="search-tag">网站搭建</span>
              </div>
            </div>
          </div>
          <div class="spatial-floating-images">
            <div class="floating-card" data-parallax="1.2">
              <div class="floating-card-icon">APP</div>
              <div class="floating-card-title">提示词库</div>
            </div>
            <div class="floating-card" data-parallax="0.8">
              <div class="floating-card-icon">TOOL</div>
              <div class="floating-card-title">工具分享</div>
            </div>
            <div class="floating-card" data-parallax="1.5">
              <div class="floating-card-icon">WORK</div>
              <div class="floating-card-title">工作流</div>
            </div>
            <div class="floating-card" data-parallax="0.6">
              <div class="floating-card-icon">TIPS</div>
              <div class="floating-card-title">经验技巧</div>
            </div>
          </div>
        </div>
      </div>
      <div class="slide anomalous-slide">
        <div class="slide-base-image" style="background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=online%20community%20discussion%20AI%20technology%20forum%20dark%20modern%20design%20purple%20pink%20gradient&image_size=landscape_16_9');"></div>
        <div class="slide-reveal-layer">
          <canvas class="reveal-canvas"></canvas>
          <div class="slide-reveal-image" style="background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=AI%20community%20collaboration%20platform%20with%20glowing%20avatars%20dark%20background&image_size=landscape_16_9');"></div>
        </div>
        <canvas class="anomalous-canvas"></canvas>
        <div class="anomalous-content">
          <div class="anomalous-title">讨论组</div>
          <div class="anomalous-subtitle">AI内容、工具、项目</div>
          <div class="anomalous-particles">
            <div class="anomalous-particle" style="--delay: 0s; --x: 20%; --y: 30%;"></div>
            <div class="anomalous-particle" style="--delay: 0.5s; --x: 70%; --y: 20%;"></div>
            <div class="anomalous-particle" style="--delay: 1s; --x: 30%; --y: 60%;"></div>
            <div class="anomalous-particle" style="--delay: 1.5s; --x: 80%; --y: 50%;"></div>
            <div class="anomalous-particle" style="--delay: 2s; --x: 40%; --y: 70%;"></div>
            <div class="anomalous-particle" style="--delay: 2.5s; --x: 60%; --y: 80%;"></div>
          </div>
        </div>
        <div class="slide-content">
          <a href="bbs.html" class="slide-cta">进入讨论</a>
        </div>
      </div>
      <div class="slide">
        <div class="slide-base-image" style="background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=business%20collaboration%20AI%20services%20professional%20dark%20theme%20elegant%20purple%20accent%20modern&image_size=landscape_16_9');"></div>
        <div class="slide-reveal-layer">
          <canvas class="reveal-canvas"></canvas>
          <div class="slide-reveal-image" style="background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=AI%20business%20solutions%20professional%20presentation%20dark%20theme%20gold%20accent&image_size=landscape_16_9');"></div>
        </div>
        <div class="slide-content">
          <canvas class="particle-canvas" data-text="商务洽谈"></canvas>
          <canvas class="particle-canvas" data-text="网站、自动化、项目包装"></canvas>
          <a href="business.html" class="slide-cta">联系合作</a>
        </div>
      </div>
    </div>
    
    <div class="slide-arrow prev">
      <svg viewBox="0 0 24 24">
        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </div>
    <div class="slide-arrow next">
      <svg viewBox="0 0 24 24">
        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
      </svg>
    </div>
    
    <div class="slide-nav">
      <div class="slide-dot active"></div>
      <div class="slide-dot"></div>
      <div class="slide-dot"></div>
      <div class="slide-dot"></div>
      <div class="slide-dot"></div>
    </div>
  </div>

  <div class="more-menu">
    <a href="tools.html" class="more-menu-item">
      <svg viewBox="0 0 24 24"><path d="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.37-.3-.59-.22l-2.49 1c-.52-.39-1.08-.7-1.66-.94l-.38-2.65c-.03-.24-.24-.42-.48-.42h-4c-.24 0-.45.18-.48.42l-.38 2.65c-.58.24-1.14.55-1.66.94l-2.49-1c-.22-.08-.47 0-.59.22l-2 3.46c-.12.22-.07.49.12.64l2.11 1.65c-.04.32-.07.64-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.37.3.59.22l2.49-1c.52.39 1.08.7 1.66.94l.38 2.65c.03.24.24.42.48.42h4c.24 0 .45-.18.48-.42l.38-2.65c.58-.24 1.14-.55 1.66-.94l2.49 1c.22.08.47 0 .59-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
      <span>AI工具箱</span>
    </a>
    <a href="go.html" class="more-menu-item">
      <svg viewBox="0 0 24 24"><path d="M10 6v2h2V6h2v6h2V6h2v10H10V6zm-8 0v10h2V6H2zm0 12h16v2H2v-2z"/></svg>
      <span>外部入口</span>
    </a>
    <a href="about.html" class="more-menu-item">
      <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      <span>关于宝宝爱AI</span>
    </a>
  </div>

  <div class="mobile-nav-overlay">
    <div class="mobile-nav-close">
      <svg viewBox="0 0 24 24">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </div>
    <a href="index.html" class="mobile-nav-item active">首页</a>
    <a href="logs.html" class="mobile-nav-item">日志</a>
    <a href="works.html" class="mobile-nav-item">作品</a>
    <a href="bbs.html" class="mobile-nav-item">讨论组</a>
    <a href="share.html" class="mobile-nav-item">AI分享</a>
    <a href="business.html" class="mobile-nav-item">商务洽谈</a>
    <a href="tools.html" class="mobile-nav-item">AI工具箱</a>
    <a href="go.html" class="mobile-nav-item">外部入口</a>
    <a href="about.html" class="mobile-nav-item">关于宝宝爱AI</a>
  </div>

  <div class="search-overlay">
    <div class="search-input-wrapper">
      <input type="text" class="search-input" placeholder="搜索 AI 内容、作品、提示词...">
      <div class="search-close">
        <svg viewBox="0 0 24 24">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </div>
    </div>
    <div class="search-suggestions">
      <div class="search-suggestions-title">热门搜索</div>
      <div class="search-tags">
        <span class="search-tag">提示词</span>
        <span class="search-tag">AI图片</span>
        <span class="search-tag">AI视频</span>
        <span class="search-tag">网站搭建</span>
        <span class="search-tag">自动化</span>
        <span class="search-tag">作品案例</span>
        <span class="search-tag">商务合作</span>
      </div>
    </div>
    <div class="search-links">
      <a href="logs.html" class="search-link-item">
        <svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
        <span>日志</span>
      </a>
      <a href="works.html" class="search-link-item">
        <svg viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
        <span>作品</span>
      </a>
      <a href="share.html" class="search-link-item">
        <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
        <span>AI分享</span>
      </a>
    </div>
  </div>

  <footer class="footer">
    <div class="footer-text">© 2024 宝宝爱AI · 持续更新的 AI 工作门户</div>
    <div class="footer-links">
      <a href="about.html" class="footer-link">关于</a>
      <a href="business.html" class="footer-link">商务合作</a>
    </div>
  </footer>

  <script src="js/main.js"></script>
</body>
</html>
